{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "npc.meta.resolve_context.request.schema.json",
  "title": "NpcMetaResolveContextRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["npc_id", "player_id"],
  "properties": {
    "npc_id": {
      "type": "string",
      "format": "uuid"
    },
    "player_id": {
      "type": "string",
      "minLength": 1
    },
    "player_name": {
      "type": "string"
    },
    "player_role": {
      "type": "string"
    },
    "world_snapshot": {
      "type": "string"
    }
  }
}
