{
  "realm": "idklol",
  "enabled": true,
  "registrationAllowed": true,
  "accessTokenLifespan": 36000,
  "accessTokenLifespanForImplicitFlow": 36000,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "roles": {
    "realm": [
      { "name": "admin" },
      { "name": "user" }
    ]
  },
  "users": [
    {
      "username": "adminuser",
      "firstName": "Admin",
      "lastName": "User",
      "email": "adminuser@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "admin123" }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "normaluser",
      "firstName": "Normal",
      "lastName": "User",
      "email": "normaluser@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "user123" }
      ],
      "realmRoles": ["user"]
    }
  ],
  "clients": [
    {
      "clientId": "idklol-chat",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "secret": "chat-client-secret-12345",
      "redirectUris": [
        "http://localhost/*"
      ]
    },
    {
      "clientId": "idklol-developer-key",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "secret": "dev-secret-12345"
    },
    {
      "clientId": "idklol-characters",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*"
      ],
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}